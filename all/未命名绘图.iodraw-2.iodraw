        </mxCell>
        <mxCell id="82Dsms7V7bGpNubbrD2n-10" value="&lt;b&gt;Path 1: Topology Attn&lt;/b&gt;&lt;br&gt;&lt;br&gt;neighbors = G_LE-adj nodes&lt;br&gt;(per-window, static)&lt;br&gt;multi-head Attn + inactive mask&lt;br&gt;↓ h_topo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="130" y="1025" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="82Dsms7V7bGpNubbrD2n-11" value="&lt;b&gt;Path 2: Functional Attn&lt;/b&gt;&lt;br&gt;&lt;br&gt;neighbors = top-k cosine on z_func&lt;br&gt;(dynamic per forward)&lt;br&gt;multi-head Attn + inactive mask&lt;br&gt;↓ h_func" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="530" y="1025" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="82Dsms7V7bGpNubbrD2n-12" value="&lt;b&gt;Fusion:&lt;/b&gt; concat([h_station; h_topo; h_func]) → MLP (96→64→32) + LayerNorm → &lt;b&gt;h_ctx (32-d)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b9d7a8;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="230" y="1210" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="82Dsms7V7bGpNubbrD2n-13" value="&lt;b&gt;m05 Decoder&lt;/b&gt;&lt;br&gt;Low-rank bilinear(h_ctx[o], h_ctx[d])&lt;br&gt;× distance gate (2·σ(MLP(dist)))&lt;br&gt;→ scaled softplus (τ=5, ε=1e-4) → μ̂_OD" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
