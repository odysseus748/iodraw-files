        <mxCell id="82Dsms7V7bGpNubbrD2n-4" value="&lt;b&gt;m01 TemporalEncoder&lt;/b&gt;&lt;br&gt;&lt;br&gt;station_emb (lookup table)&lt;br&gt;for existing stations&lt;br&gt;&lt;br&gt;NewStationEmb (z_func → emb)&lt;br&gt;for new stations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="310" width="290" height="180" as="geometry" />
