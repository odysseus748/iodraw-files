        <mxCell id="82Dsms7V7bGpNubbrD2n-5" value="&lt;b&gt;h_v_time (32-d)&lt;/b&gt;&lt;br&gt;unified embedding" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="605" y="520" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="82Dsms7V7bGpNubbrD2n-6" value="Hot-Swap (Algorithm 1):&lt;br&gt;end of each epoch&lt;br&gt;station_emb[s_new] ← NewStationEmbedder(z_func)&lt;br&gt;(writeback, no gradient)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;dashed=1;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="540" y="600" width="320" height="90" as="geometry" />
        </mxCell>
        <mxCell id="82Dsms7V7bGpNubbrD2n-7" value="&lt;b&gt;m02 SpatialEncoder (GraphSAGE)&lt;/b&gt;&lt;br&gt;3-layer SAGE on G_LE → h_v_space (32-d, per-station)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="230" y="720" width="470" height="70" as="geometry" />
        </mxCell>
        <mxCell id="82Dsms7V7bGpNubbrD2n-8" value="&lt;b&gt;fuse:&lt;/b&gt; [h_v_time; h_v_space; z_func] → 32-d → LayerNorm → &lt;b&gt;h_station&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bac8e0;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="230" y="815" width="470" height="60" as="geometry" />
        </mxCell>
        <mxCell id="82Dsms7V7bGpNubbrD2n-9" value="&lt;b&gt;CONTRIBUTION 2 — Station-Level Dual-Neighborhood Local Attention&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=13;spacingTop=8;arcSize=3;" vertex="1" parent="1">
