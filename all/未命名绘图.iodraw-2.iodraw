        <mxCell id="82Dsms7V7bGpNubbrD2n-1" value="&lt;b&gt;INPUTS&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Functional feat. (POI + pop, 25-d)&lt;br&gt;• G_LE topology graph (per window)&lt;br&gt;• Station ID&lt;br&gt;• Distance feat." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
